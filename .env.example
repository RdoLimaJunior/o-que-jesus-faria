# Local development environment variables
# Copy this file to .env.local and fill in your actual API keys

# Groq API Key (for fast LLM inference)
GROQ_API_KEY=your_groq_api_key_here

# Nvidia ResembleAI API Key (for text-to-speech in Portuguese)
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# BíbliaAPI Key (optional - for tracking usage and limits)
# Generate at: https://bibliaapi.com.br/admin/api-keys
# Free plan available (no key required to use)
BIBLIAAPI_KEY=your_bibliaapi_key_here
